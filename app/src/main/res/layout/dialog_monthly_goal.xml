<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_home_balance_card"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/tvMonthlyGoalDialogTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/monthly_goal_title"
        android:textColor="@color/text_primary"
        android:textSize="20sp"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/etMonthlyGoalAmount"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="14dp"
        android:background="@drawable/bg_input_surface"
        android:backgroundTint="@null"
        android:gravity="center_vertical"
        android:hint="@string/monthly_goal_amount_hint"
        android:inputType="numberDecimal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_hint" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:text="@string/monthly_goal_sources_title"
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        android:textStyle="bold" />

    <CheckBox
        android:id="@+id/cbMonthlyGoalExpenses"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:buttonTint="@color/calendar_accent"
        android:text="@string/monthly_goal_include_expenses"
        android:textColor="@color/text_primary"
        android:textSize="14sp" />

    <CheckBox
        android:id="@+id/cbMonthlyGoalSubscriptions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:buttonTint="@color/calendar_accent"
        android:text="@string/monthly_goal_include_subscriptions"
        android:textColor="@color/text_primary"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/tvMonthlyGoalCategoriesTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/monthly_goal_categories_title"
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        android:textStyle="bold" />

    <LinearLayout
        android:id="@+id/layoutMonthlyGoalCategories"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="vertical">

        <Button
            android:id="@+id/btnCancelMonthlyGoalDialog"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:background="@drawable/bg_button_light"
            android:backgroundTint="@null"
            app:backgroundTint="@null"
            android:fontFamily="sans-serif-medium"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:text="@string/cancel"
            android:textAllCaps="false"
            android:textColor="@color/button_text_dark" />

        <Button
            android:id="@+id/btnDeleteMonthlyGoalDialog"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_button_light"
            android:backgroundTint="@null"
            app:backgroundTint="@null"
            android:fontFamily="sans-serif-medium"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:text="@string/monthly_goal_delete"
            android:textAllCaps="false"
            android:textColor="@color/button_text_dark"
            android:visibility="gone" />

        <Button
            android:id="@+id/btnSaveMonthlyGoalDialog"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_button_dark"
            android:backgroundTint="@null"
            app:backgroundTint="@null"
            android:fontFamily="sans-serif-medium"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:text="@string/save_changes"
            android:textAllCaps="false"
            android:textColor="@color/button_text_light" />
    </LinearLayout>

</LinearLayout>
