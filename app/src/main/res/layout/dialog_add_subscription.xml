<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_card_primary"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/tvSubscriptionDialogTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/add_subscription"
        android:textColor="@color/text_primary"
        android:textSize="20sp"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/etName"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="14dp"
        android:background="@drawable/bg_input_surface"
        android:backgroundTint="@null"
        android:gravity="center_vertical"
        android:hint="@string/name"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_hint" />

    <EditText
        android:id="@+id/etAmount"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_input_surface"
        android:gravity="center_vertical"
        android:hint="@string/amount"
        android:inputType="numberDecimal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_hint" />

    <Spinner
        android:id="@+id/spinnerPeriod"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_input_surface"
        android:backgroundTint="@null"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:popupBackground="@drawable/bg_spinner_popup"
        android:spinnerMode="dropdown" />

    <Spinner
        android:id="@+id/spinnerSubscriptionAccount"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_input_surface"
        android:backgroundTint="@null"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:popupBackground="@drawable/bg_spinner_popup"
        android:spinnerMode="dropdown" />

    <Button
        android:id="@+id/btnSubscriptionDate"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_input_surface"
        android:backgroundTint="@null"
        app:backgroundTint="@null"
        android:fontFamily="sans-serif-medium"
        android:gravity="start|center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:text="@string/select_charge_date"
        android:textAllCaps="false"
        android:textColor="@color/text_primary" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="vertical">

        <Button
            android:id="@+id/btnCancelSubscriptionDialog"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:background="@drawable/bg_button_light"
            android:backgroundTint="@null"
            app:backgroundTint="@null"
            android:fontFamily="sans-serif-medium"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:text="@string/cancel"
            android:textAllCaps="false"
            android:textColor="@color/button_text_dark" />

        <Button
            android:id="@+id/btnDeleteSubscriptionDialog"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_button_light"
            android:backgroundTint="@null"
            app:backgroundTint="@null"
            android:fontFamily="sans-serif-medium"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:text="@string/delete_subscription"
            android:textAllCaps="false"
            android:textColor="@color/button_text_dark"
            android:visibility="gone" />

        <Button
            android:id="@+id/btnPrimarySubscriptionDialog"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_button_dark"
            android:backgroundTint="@null"
            app:backgroundTint="@null"
            android:fontFamily="sans-serif-medium"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:text="@string/add_subscription"
            android:textAllCaps="false"
            android:textColor="@color/button_text_light" />
    </LinearLayout>

</LinearLayout>
