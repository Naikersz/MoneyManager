<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_card_primary"
    android:orientation="vertical"
    android:padding="12dp">

    <Button
        android:id="@+id/btnAddMenuIncome"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:background="@drawable/bg_settings_row"
        android:backgroundTint="@null"
        app:backgroundTint="@null"
        android:gravity="start|center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:text="@string/add_income_menu"
        android:textAllCaps="false"
        android:textColor="@color/text_primary"
        android:textSize="15sp" />

    <Button
        android:id="@+id/btnAddMenuExpense"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginTop="6dp"
        android:background="@drawable/bg_settings_row"
        android:backgroundTint="@null"
        app:backgroundTint="@null"
        android:gravity="start|center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:text="@string/add_expense_menu"
        android:textAllCaps="false"
        android:textColor="@color/text_primary"
        android:textSize="15sp" />

    <Button
        android:id="@+id/btnAddMenuSubscription"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginTop="6dp"
        android:background="@drawable/bg_settings_row"
        android:backgroundTint="@null"
        app:backgroundTint="@null"
        android:gravity="start|center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:text="@string/add_subscription_menu"
        android:textAllCaps="false"
        android:textColor="@color/text_primary"
        android:textSize="15sp" />
</LinearLayout>
