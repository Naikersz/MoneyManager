<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app_surface"
    android:fitsSystemWindows="true"
    android:orientation="vertical"
    android:paddingStart="0dp"
    android:paddingTop="0dp"
    android:paddingEnd="0dp"
    android:paddingBottom="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingTop="12dp"
        android:paddingEnd="12dp">

        <LinearLayout
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@drawable/bg_header_avatar_ring"
            android:gravity="center"
            android:orientation="horizontal">

            <View
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:background="@drawable/bg_header_avatar_white" />

            <View
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginStart="-4dp"
                android:background="@drawable/bg_header_avatar_blue" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:fontFamily="sans-serif-medium"
            android:text="@string/app_display_name"
            android:textColor="@color/text_primary"
            android:textSize="25sp"
            android:textStyle="bold" />
    </LinearLayout>

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPagerSections"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        android:layout_weight="1" />

    <LinearLayout
        android:id="@+id/layoutSectionSelector"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:background="@drawable/bg_bottom_nav_container"
        android:elevation="0dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="6dp">

        <FrameLayout
            android:id="@+id/btnSectionHome"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1">

            <LinearLayout
                android:id="@+id/navHomeContent"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_bottom_nav_item_selected"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingStart="5dp"
                android:paddingTop="3dp"
                android:paddingEnd="5dp"
                android:paddingBottom="3dp">

                <ImageView
                    android:id="@+id/ivSectionHome"
                    android:layout_width="17dp"
                    android:layout_height="17dp"
                    android:src="@drawable/ic_nav_home"
                    android:tint="@color/text_primary" />

                <TextView
                    android:id="@+id/tvSectionHome"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:fontFamily="sans-serif-medium"
                    android:gravity="center"
                    android:maxLines="2"
                    android:text="@string/page_home"
                    android:textColor="@color/text_primary"
                    android:textSize="10.5sp" />
            </LinearLayout>
        </FrameLayout>

        <FrameLayout
            android:id="@+id/btnSectionCategories"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_marginStart="4dp"
            android:layout_weight="1">

            <LinearLayout
                android:id="@+id/navCategoriesContent"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_bottom_nav_item_unselected"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingStart="5dp"
                android:paddingTop="3dp"
                android:paddingEnd="5dp"
                android:paddingBottom="3dp">

                <ImageView
                    android:id="@+id/ivSectionCategories"
                    android:layout_width="17dp"
                    android:layout_height="17dp"
                    android:src="@drawable/ic_nav_categories"
                    android:tint="@color/text_secondary" />

                <TextView
                    android:id="@+id/tvSectionCategories"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:fontFamily="sans-serif-medium"
                    android:gravity="center"
                    android:maxLines="2"
                    android:text="@string/page_categories"
                    android:textColor="@color/text_secondary"
                    android:textSize="10.5sp" />
            </LinearLayout>
        </FrameLayout>

        <FrameLayout
            android:id="@+id/btnSectionCalendar"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_marginStart="4dp"
            android:layout_weight="1">

            <LinearLayout
                android:id="@+id/navCalendarContent"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_bottom_nav_item_unselected"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingStart="5dp"
                android:paddingTop="3dp"
                android:paddingEnd="5dp"
                android:paddingBottom="3dp">

                <ImageView
                    android:id="@+id/ivSectionCalendar"
                    android:layout_width="17dp"
                    android:layout_height="17dp"
                    android:src="@drawable/ic_nav_calendar"
                    android:tint="@color/text_secondary" />

                <TextView
                    android:id="@+id/tvSectionCalendar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:fontFamily="sans-serif-medium"
                    android:gravity="center"
                    android:maxLines="2"
                    android:text="@string/page_calendar"
                    android:textColor="@color/text_secondary"
                    android:textSize="10.5sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvSectionCalendarBadge"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_gravity="top|end"
                android:layout_marginTop="4dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_bottom_nav_badge"
                android:gravity="center"
                android:text="0"
                android:textColor="@android:color/white"
                android:textSize="7sp"
                android:textStyle="bold"
                android:visibility="gone" />
        </FrameLayout>

        <FrameLayout
            android:id="@+id/btnSectionSettings"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_marginStart="4dp"
            android:layout_weight="1">

            <LinearLayout
                android:id="@+id/navSettingsContent"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_bottom_nav_item_unselected"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingStart="5dp"
                android:paddingTop="3dp"
                android:paddingEnd="5dp"
                android:paddingBottom="3dp">

                <ImageView
                    android:id="@+id/ivSectionSettings"
                    android:layout_width="17dp"
                    android:layout_height="17dp"
                    android:src="@drawable/ic_nav_settings"
                    android:tint="@color/text_secondary" />

                <TextView
                    android:id="@+id/tvSectionSettings"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:fontFamily="sans-serif-medium"
                    android:gravity="center"
                    android:maxLines="2"
                    android:text="@string/page_settings"
                    android:textColor="@color/text_secondary"
                    android:textSize="10.5sp" />
            </LinearLayout>
        </FrameLayout>
    </LinearLayout>

</LinearLayout>
