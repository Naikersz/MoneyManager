<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="false"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_home_balance_card"
        android:orientation="vertical"
        android:padding="14dp">

        <TextView
            android:id="@+id/tvTransferDialogTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:text="@string/add_transfer"
            android:textColor="@color/text_primary"
            android:textSize="19sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etTransferAmount"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_home_panel"
            android:backgroundTint="@null"
            android:gravity="center_vertical"
            android:hint="0,00"
            android:inputType="numberDecimal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:textSize="28sp"
            android:textStyle="bold" />

        <Spinner
            android:id="@+id/spinnerTransferFrom"
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_home_panel"
            android:backgroundTint="@null"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:popupBackground="@drawable/bg_spinner_popup"
            android:spinnerMode="dropdown" />

        <Spinner
            android:id="@+id/spinnerTransferTo"
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_home_panel"
            android:backgroundTint="@null"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:popupBackground="@drawable/bg_spinner_popup"
            android:spinnerMode="dropdown" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnTransferToday"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:background="@drawable/bg_button_light"
                android:backgroundTint="@null"
                android:minHeight="0dp"
                android:text="@string/date_today"
                android:textAllCaps="false"
                android:textColor="@color/button_text_dark"
                android:textSize="12sp"
                app:backgroundTint="@null" />

            <Button
                android:id="@+id/btnTransferYesterday"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_button_light"
                android:backgroundTint="@null"
                android:minHeight="0dp"
                android:text="@string/date_yesterday"
                android:textAllCaps="false"
                android:textColor="@color/button_text_dark"
                android:textSize="12sp"
                app:backgroundTint="@null" />

            <Button
                android:id="@+id/btnTransferDate"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1.4"
                android:background="@drawable/bg_home_panel"
                android:backgroundTint="@null"
                android:minHeight="0dp"
                android:text="@string/select_transfer_date"
                android:textAllCaps="false"
                android:textColor="@color/text_primary"
                android:textSize="12sp"
                app:backgroundTint="@null" />
        </LinearLayout>

        <Button
            android:id="@+id/btnToggleTransferDetails"
            android:layout_width="match_parent"
            android:layout_height="34dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_bottom_nav_container"
            android:backgroundTint="@null"
            android:minHeight="0dp"
            android:text="@string/more_details"
            android:textAllCaps="false"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            app:backgroundTint="@null" />

        <LinearLayout
            android:id="@+id/layoutTransferDetails"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <EditText
                android:id="@+id/etTransferNote"
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_input_surface"
                android:backgroundTint="@null"
                android:gravity="center_vertical"
                android:hint="@string/transfer_note_hint"
                android:inputType="textCapSentences"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnCancelTransferDialog"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_weight="1"
                android:background="@drawable/bg_button_light"
                android:backgroundTint="@null"
                android:text="@string/cancel"
                android:textAllCaps="false"
                android:textColor="@color/button_text_dark"
                app:backgroundTint="@null" />

            <Button
                android:id="@+id/btnDeleteTransferDialog"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_button_light"
                android:backgroundTint="@null"
                android:text="@string/delete_entry"
                android:textAllCaps="false"
                android:textColor="@color/button_text_dark"
                app:backgroundTint="@null" />

            <Button
                android:id="@+id/btnPrimaryTransferDialog"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1.4"
                android:background="@drawable/bg_button_dark"
                android:backgroundTint="@null"
                android:text="@string/add_transfer"
                android:textAllCaps="false"
                android:textColor="@color/button_text_light"
                app:backgroundTint="@null" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
