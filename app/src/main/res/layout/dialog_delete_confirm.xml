<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_card_primary"
    android:orientation="vertical"
    android:padding="18dp">

    <TextView
        android:id="@+id/tvDeleteConfirmTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/delete_confirm_title"
        android:textColor="@color/text_primary"
        android:textSize="20sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-medium" />

    <TextView
        android:id="@+id/tvDeleteConfirmMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:textColor="@color/text_secondary"
        android:textSize="15sp" />

    <Button
        android:id="@+id/btnCancelDeleteConfirm"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="18dp"
        android:background="@drawable/bg_button_light"
        android:backgroundTint="@null"
        app:backgroundTint="@null"
        android:text="@string/cancel"
        android:textAllCaps="false"
        android:textColor="@color/button_text_dark"
        android:textSize="14sp" />

    <Button
        android:id="@+id/btnDeleteDeleteConfirm"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_button_dark"
        android:backgroundTint="@null"
        app:backgroundTint="@null"
        android:text="@string/delete_entry"
        android:textAllCaps="false"
        android:textColor="@color/button_text_light"
        android:textSize="14sp" />
</LinearLayout>
