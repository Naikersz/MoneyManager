<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="false"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_home_balance_card"
        android:orientation="vertical"
        android:padding="14dp">

        <TextView
            android:id="@+id/tvAccountDialogTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:text="@string/edit_account_name"
            android:textColor="@color/text_primary"
            android:textSize="19sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etAccountBalance"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_home_panel"
            android:backgroundTint="@null"
            android:gravity="center_vertical"
            android:hint="@string/account_balance"
            android:inputType="numberDecimal|numberSigned"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:textSize="28sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etAccountName"
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_input_surface"
            android:backgroundTint="@null"
            android:gravity="center_vertical"
            android:hint="@string/name"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/layoutQuickAccountTypes"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal" />
        </HorizontalScrollView>

        <Spinner
            android:id="@+id/spinnerAccountType"
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_home_panel"
            android:backgroundTint="@null"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:popupBackground="@drawable/bg_spinner_popup"
            android:spinnerMode="dropdown"
            android:visibility="gone" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnCancelAccountDialog"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_weight="1"
                android:background="@drawable/bg_button_light"
                android:backgroundTint="@null"
                android:text="@string/cancel"
                android:textAllCaps="false"
                android:textColor="@color/button_text_dark"
                app:backgroundTint="@null" />

            <Button
                android:id="@+id/btnDeleteAccountDialog"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_button_light"
                android:backgroundTint="@null"
                android:text="@string/delete_entry"
                android:textAllCaps="false"
                android:textColor="@color/button_text_dark"
                android:visibility="gone"
                app:backgroundTint="@null" />

            <Button
                android:id="@+id/btnSaveAccountDialog"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1.4"
                android:background="@drawable/bg_button_dark"
                android:backgroundTint="@null"
                android:text="@string/save_changes"
                android:textAllCaps="false"
                android:textColor="@color/button_text_light"
                app:backgroundTint="@null" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
