<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_home_balance_card"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:id="@+id/tvManageTagsTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/manage_tags_title"
        android:textColor="@color/text_primary"
        android:textSize="20sp"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/etManagedTags"
        android:layout_width="match_parent"
        android:layout_height="96dp"
        android:layout_marginTop="14dp"
        android:background="@drawable/bg_input_surface"
        android:gravity="top|start"
        android:hint="@string/tags_hint"
        android:inputType="textMultiLine|textCapWords"
        android:padding="14dp"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_hint" />

    <EditText
        android:id="@+id/etManagedSubcategories"
        android:layout_width="match_parent"
        android:layout_height="96dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_input_surface"
        android:gravity="top|start"
        android:hint="@string/subcategories_hint"
        android:inputType="textMultiLine|textCapWords"
        android:padding="14dp"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_hint" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnCancelManageTags"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:background="@drawable/bg_button_light"
            android:text="@string/cancel"
            android:textAllCaps="false"
            android:textColor="@color/button_text_dark" />

        <Button
            android:id="@+id/btnSaveManageTags"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:background="@drawable/bg_button_dark"
            android:text="@string/save_changes"
            android:textAllCaps="false"
            android:textColor="@color/button_text_light" />
    </LinearLayout>
</LinearLayout>
