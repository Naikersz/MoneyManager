<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_card_primary"
    android:orientation="vertical"
    android:padding="18dp">

    <TextView
        android:id="@+id/tvAccountDialogTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/edit_account_name"
        android:textColor="@color/text_primary"
        android:textSize="20sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-medium" />

    <EditText
        android:id="@+id/etAccountName"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="14dp"
        android:background="@drawable/bg_input_surface"
        android:gravity="center_vertical"
        android:hint="@string/name"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_secondary" />

    <Spinner
        android:id="@+id/spinnerAccountType"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_input_surface"
        android:backgroundTint="@null"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:popupBackground="@drawable/bg_spinner_popup"
        android:spinnerMode="dropdown" />

    <EditText
        android:id="@+id/etAccountBalance"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_input_surface"
        android:backgroundTint="@null"
        android:gravity="center_vertical"
        android:hint="@string/account_balance"
        android:inputType="numberDecimal|numberSigned"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_secondary" />

    <Button
        android:id="@+id/btnCancelAccountDialog"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="18dp"
        android:background="@drawable/bg_button_light"
        android:backgroundTint="@null"
        app:backgroundTint="@null"
        android:text="@string/cancel"
        android:textAllCaps="false"
        android:textColor="@color/button_text_dark"
        android:textSize="14sp" />

    <Button
        android:id="@+id/btnDeleteAccountDialog"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_button_light"
        android:backgroundTint="@null"
        app:backgroundTint="@null"
        android:text="@string/delete_entry"
        android:textAllCaps="false"
        android:textColor="@color/button_text_dark"
        android:textSize="14sp"
        android:visibility="gone" />

    <Button
        android:id="@+id/btnSaveAccountDialog"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_button_dark"
        android:backgroundTint="@null"
        app:backgroundTint="@null"
        android:text="@string/save_changes"
        android:textAllCaps="false"
        android:textColor="@color/button_text_light"
        android:textSize="14sp" />
</LinearLayout>
