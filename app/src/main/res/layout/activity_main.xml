<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app_surface"
    android:fitsSystemWindows="true"
    android:paddingStart="0dp"
    android:paddingTop="0dp"
    android:paddingEnd="0dp"
    android:paddingBottom="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingTop="10dp"
            android:paddingEnd="16dp">

            <LinearLayout
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:background="@drawable/bg_header_avatar_ring"
                android:gravity="center"
                android:orientation="horizontal">

                <View
                    android:layout_width="13dp"
                    android:layout_height="13dp"
                    android:background="@drawable/bg_header_avatar_white" />

                <View
                    android:layout_width="13dp"
                    android:layout_height="13dp"
                    android:layout_marginStart="-4dp"
                    android:background="@drawable/bg_header_avatar_blue" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:fontFamily="sans-serif-medium"
                android:text="@string/app_display_name"
                android:textColor="@color/text_primary"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>

        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/viewPagerSections"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="8dp"
            android:layout_weight="1" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutSectionSelector"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginStart="34dp"
        android:layout_marginTop="4dp"
        android:layout_marginEnd="34dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/bg_bottom_nav_container"
        android:elevation="0dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="0dp">

        <FrameLayout
            android:id="@+id/btnSectionHome"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1">

            <LinearLayout
                android:id="@+id/navHomeContent"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_bottom_nav_item_selected"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingStart="4dp"
                android:paddingTop="2dp"
                android:paddingEnd="4dp"
                android:paddingBottom="2dp">

                <ImageView
                    android:id="@+id/ivSectionHome"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_nav_home"
                    android:tint="@color/text_primary" />

                <TextView
                    android:id="@+id/tvSectionHome"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:fontFamily="sans-serif-medium"
                    android:gravity="center"
                    android:maxLines="2"
                    android:text="@string/page_home"
                    android:textColor="@color/text_primary"
                    android:textSize="9sp" />
            </LinearLayout>
        </FrameLayout>

        <FrameLayout
            android:id="@+id/btnSectionCategories"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginStart="6dp"
            android:layout_weight="1">

            <LinearLayout
                android:id="@+id/navCategoriesContent"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_bottom_nav_item_unselected"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingStart="4dp"
                android:paddingTop="2dp"
                android:paddingEnd="4dp"
                android:paddingBottom="2dp">

                <ImageView
                    android:id="@+id/ivSectionCategories"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_nav_categories"
                    android:tint="@color/text_secondary" />

                <TextView
                    android:id="@+id/tvSectionCategories"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:fontFamily="sans-serif-medium"
                    android:gravity="center"
                    android:maxLines="2"
                    android:text="@string/page_categories"
                    android:textColor="@color/text_secondary"
                    android:textSize="9sp" />
            </LinearLayout>
        </FrameLayout>

        <FrameLayout
            android:id="@+id/btnSectionCalendar"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginStart="6dp"
            android:layout_weight="1">

            <LinearLayout
                android:id="@+id/navCalendarContent"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_bottom_nav_item_unselected"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingStart="4dp"
                android:paddingTop="2dp"
                android:paddingEnd="4dp"
                android:paddingBottom="2dp">

                <ImageView
                    android:id="@+id/ivSectionCalendar"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_nav_calendar"
                    android:tint="@color/text_secondary" />

                <TextView
                    android:id="@+id/tvSectionCalendar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:fontFamily="sans-serif-medium"
                    android:gravity="center"
                    android:maxLines="2"
                    android:text="@string/page_calendar"
                    android:textColor="@color/text_secondary"
                    android:textSize="9sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvSectionCalendarBadge"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_gravity="top|end"
                android:layout_marginTop="3dp"
                android:layout_marginEnd="7dp"
                android:background="@drawable/bg_bottom_nav_badge"
                android:gravity="center"
                android:text="0"
                android:textColor="@color/home_mint"
                android:textSize="8sp"
                android:textStyle="bold"
                android:visibility="gone" />
        </FrameLayout>

        <FrameLayout
            android:id="@+id/btnSectionAnalytics"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginStart="6dp"
            android:layout_weight="1">

            <LinearLayout
                android:id="@+id/navAnalyticsContent"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_bottom_nav_item_unselected"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingStart="4dp"
                android:paddingTop="2dp"
                android:paddingEnd="4dp"
                android:paddingBottom="2dp">

                <ImageView
                    android:id="@+id/ivSectionAnalytics"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_nav_analytics"
                    android:tint="@color/text_secondary" />

                <TextView
                    android:id="@+id/tvSectionAnalytics"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:fontFamily="sans-serif-medium"
                    android:gravity="center"
                    android:maxLines="2"
                    android:text="@string/page_analytics"
                    android:textColor="@color/text_secondary"
                    android:textSize="9sp" />
            </LinearLayout>
        </FrameLayout>

        <FrameLayout
            android:id="@+id/btnSectionSettings"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginStart="6dp"
            android:layout_weight="1">

            <LinearLayout
                android:id="@+id/navSettingsContent"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_bottom_nav_item_unselected"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingStart="4dp"
                android:paddingTop="2dp"
                android:paddingEnd="4dp"
                android:paddingBottom="2dp">

                <ImageView
                    android:id="@+id/ivSectionSettings"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_nav_settings"
                    android:tint="@color/text_secondary" />

                <TextView
                    android:id="@+id/tvSectionSettings"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:fontFamily="sans-serif-medium"
                    android:gravity="center"
                    android:maxLines="2"
                    android:text="@string/page_settings"
                    android:textColor="@color/text_secondary"
                    android:textSize="9sp" />
            </LinearLayout>
        </FrameLayout>
    </LinearLayout>

</FrameLayout>
