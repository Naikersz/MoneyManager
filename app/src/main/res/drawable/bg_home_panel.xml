<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/home_panel_pressed" />
            <corners android:radius="18dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="315"
                android:endColor="@color/dashboard_panel_end"
                android:startColor="@color/dashboard_panel_start" />
            <stroke
                android:width="1dp"
                android:color="@color/home_line" />
            <corners android:radius="18dp" />
        </shape>
    </item>
</selector>
