<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_home_balance_card"
    android:orientation="vertical"
    android:padding="18dp">

    <TextView
        android:id="@+id/tvCalendarDayDialogTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/text_primary"
        android:textSize="20sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-medium" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:fillViewport="false"
        android:scrollbars="vertical">

        <LinearLayout
            android:id="@+id/layoutCalendarDayDialogEvents"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />
    </ScrollView>

    <LinearLayout
        android:id="@+id/layoutCalendarPaymentActions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="vertical"
        android:visibility="gone">

        <Button
            android:id="@+id/btnCalendarMarkPaid"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:background="@drawable/bg_button_dark"
            android:backgroundTint="@null"
            app:backgroundTint="@null"
            android:text="@string/mark_paid"
            android:textAllCaps="false"
            android:textColor="@color/button_text_light" />

        <Button
            android:id="@+id/btnCalendarSkipPayment"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_button_light"
            android:backgroundTint="@null"
            app:backgroundTint="@null"
            android:text="@string/skip_payment"
            android:textAllCaps="false"
            android:textColor="@color/button_text_dark" />
    </LinearLayout>

    <Button
        android:id="@+id/btnCloseCalendarDayDialog"
        android:layout_width="match_parent"
        android:layout_height="46dp"
        android:layout_marginTop="18dp"
        android:background="@drawable/bg_button_dark"
        android:backgroundTint="@null"
        app:backgroundTint="@null"
        android:text="@string/close"
        android:textAllCaps="false"
        android:textColor="@color/button_text_light" />
</LinearLayout>
