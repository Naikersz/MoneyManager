<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_home_balance_card"
    android:orientation="vertical"
    android:padding="14dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="4dp"
        android:layout_marginBottom="10dp"
        android:text="@string/calendar_account_picker_title"
        android:textColor="@color/text_primary"
        android:textSize="18sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-medium" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="320dp"
        android:fillViewport="false"
        android:scrollbars="vertical">

        <LinearLayout
            android:id="@+id/layoutAccountPickerOptions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />
    </ScrollView>

    <Button
        android:id="@+id/btnCloseAccountPicker"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_button_light"
        android:backgroundTint="@null"
        app:backgroundTint="@null"
        android:text="@string/close"
        android:textAllCaps="false"
        android:textColor="@color/button_text_dark"
        android:textSize="14sp" />
</LinearLayout>
