<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app_surface"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:paddingStart="14dp"
    android:paddingEnd="14dp"
    android:paddingBottom="56dp"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_home_balance_card"
            android:elevation="0dp"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="sans-serif-medium"
                    android:text="@string/page_categories"
                    android:textColor="@color/text_primary"
                    android:textSize="19sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutAssetsTabs"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/bg_tabs_container"
                android:orientation="horizontal"
                android:padding="4dp">

                <Button
                    android:id="@+id/btnAssetsAccountsTab"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/bg_tab_chip_selected"
                    android:backgroundTint="@null"
                    android:fontFamily="sans-serif-medium"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:text="@string/assets_tab_accounts"
                    android:textAllCaps="false"
                    android:textColor="@color/home_dark_text"
                    android:textSize="13sp"
                    app:backgroundTint="@null" />

                <Button
                    android:id="@+id/btnAssetsBudgetsTab"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginStart="4dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_tab_chip_unselected"
                    android:backgroundTint="@null"
                    android:fontFamily="sans-serif-medium"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:text="@string/assets_tab_budgets"
                    android:textAllCaps="false"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    app:backgroundTint="@null" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvEmptyCategoriesPage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/no_categories"
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/layoutCategoriesPageList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:orientation="vertical" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnAddAccountPage"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_action_mint"
                    android:backgroundTint="@null"
                    android:fontFamily="sans-serif-medium"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:text="@string/add_card_wallet"
                    android:textAllCaps="false"
                    android:textColor="@color/home_dark_text"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    app:backgroundTint="@null" />

                <Button
                    android:id="@+id/btnTransferPage"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_action_blue"
                    android:backgroundTint="@null"
                    android:fontFamily="sans-serif-medium"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:text="@string/add_transfer_menu"
                    android:textAllCaps="false"
                    android:textColor="@color/home_dark_text"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    app:backgroundTint="@null" />

                <Button
                    android:id="@+id/btnAddCategoryPage"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_action_yellow"
                    android:backgroundTint="@null"
                    android:fontFamily="sans-serif-medium"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:text="@string/add_category_short"
                    android:textAllCaps="false"
                    android:textColor="@color/home_dark_text"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    app:backgroundTint="@null" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</ScrollView>
