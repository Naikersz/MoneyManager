<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="false"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_home_balance_card"
        android:orientation="vertical"
        android:padding="14dp">

        <TextView
            android:id="@+id/tvSubscriptionDialogTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:text="@string/add_subscription"
            android:textColor="@color/text_primary"
            android:textSize="19sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etAmount"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_home_panel"
            android:backgroundTint="@null"
            android:gravity="center_vertical"
            android:hint="0,00"
            android:inputType="numberDecimal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:textSize="28sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etName"
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_input_surface"
            android:backgroundTint="@null"
            android:gravity="center_vertical"
            android:hint="@string/subscription_name_search_hint"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:clipToPadding="false"
            android:overScrollMode="never"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/layoutSubscriptionPresets"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal" />
        </HorizontalScrollView>

        <Spinner
            android:id="@+id/spinnerPeriod"
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_home_panel"
            android:backgroundTint="@null"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:popupBackground="@drawable/bg_spinner_popup"
            android:spinnerMode="dropdown" />

        <Spinner
            android:id="@+id/spinnerSubscriptionAccount"
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_home_panel"
            android:backgroundTint="@null"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:popupBackground="@drawable/bg_spinner_popup"
            android:spinnerMode="dropdown" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnSubscriptionToday"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:background="@drawable/bg_button_light"
                android:backgroundTint="@null"
                android:minHeight="0dp"
                android:text="@string/date_today"
                android:textAllCaps="false"
                android:textColor="@color/button_text_dark"
                android:textSize="12sp"
                app:backgroundTint="@null" />

            <Button
                android:id="@+id/btnSubscriptionTomorrow"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_button_light"
                android:backgroundTint="@null"
                android:minHeight="0dp"
                android:text="@string/date_tomorrow"
                android:textAllCaps="false"
                android:textColor="@color/button_text_dark"
                android:textSize="12sp"
                app:backgroundTint="@null" />

            <Button
                android:id="@+id/btnSubscriptionDate"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1.4"
                android:background="@drawable/bg_home_panel"
                android:backgroundTint="@null"
                android:minHeight="0dp"
                android:text="@string/select_charge_date"
                android:textAllCaps="false"
                android:textColor="@color/text_primary"
                android:textSize="12sp"
                app:backgroundTint="@null" />
        </LinearLayout>

        <Button
            android:id="@+id/btnToggleSubscriptionDetails"
            android:layout_width="match_parent"
            android:layout_height="34dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_bottom_nav_container"
            android:backgroundTint="@null"
            android:minHeight="0dp"
            android:text="@string/more_details"
            android:textAllCaps="false"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            app:backgroundTint="@null" />

        <LinearLayout
            android:id="@+id/layoutSubscriptionDetails"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <CheckBox
                android:id="@+id/cbSubscriptionReminder"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="8dp"
                android:buttonTint="@color/tab_badge"
                android:text="@string/payment_reminder_enabled"
                android:textColor="@color/text_primary"
                android:textSize="14sp" />

            <Spinner
                android:id="@+id/spinnerSubscriptionReminderDays"
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_home_panel"
                android:backgroundTint="@null"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:popupBackground="@drawable/bg_spinner_popup"
                android:spinnerMode="dropdown" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnCancelSubscriptionDialog"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_weight="1"
                android:background="@drawable/bg_button_light"
                android:backgroundTint="@null"
                android:text="@string/cancel"
                android:textAllCaps="false"
                android:textColor="@color/button_text_dark"
                app:backgroundTint="@null" />

            <Button
                android:id="@+id/btnDeleteSubscriptionDialog"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_button_light"
                android:backgroundTint="@null"
                android:text="@string/delete_subscription"
                android:textAllCaps="false"
                android:textColor="@color/button_text_dark"
                android:visibility="gone"
                app:backgroundTint="@null" />

            <Button
                android:id="@+id/btnPrimarySubscriptionDialog"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1.4"
                android:background="@drawable/bg_button_dark"
                android:backgroundTint="@null"
                android:text="@string/add_subscription"
                android:textAllCaps="false"
                android:textColor="@color/button_text_light"
                app:backgroundTint="@null" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
