<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_home_balance_card"
    android:orientation="vertical"
    android:padding="18dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/language_change_title"
        android:textColor="@color/text_primary"
        android:textSize="20sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-medium" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/language_change_message"
        android:textColor="@color/text_secondary"
        android:textSize="15sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:orientation="vertical">

        <Button
            android:id="@+id/btnCancelLanguageChange"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_button_light"
            android:backgroundTint="@null"
            app:backgroundTint="@null"
            android:text="@string/keep_current_language"
            android:textAllCaps="false"
            android:textColor="@color/button_text_dark"
            android:textSize="14sp" />

        <Button
            android:id="@+id/btnApplyLanguageChange"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_button_dark"
            android:backgroundTint="@null"
            app:backgroundTint="@null"
            android:text="@string/restart_now"
            android:textAllCaps="false"
            android:textColor="@color/button_text_light"
            android:textSize="14sp" />
    </LinearLayout>
</LinearLayout>
