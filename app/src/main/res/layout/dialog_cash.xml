<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_card_primary"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/edit_cash"
        android:textColor="@color/text_primary"
        android:textSize="20sp"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/etCashAmount"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="14dp"
        android:background="@drawable/bg_input_surface"
        android:backgroundTint="@null"
        android:gravity="center_vertical"
        android:hint="@string/cash_amount_hint"
        android:inputType="numberDecimal|numberSigned"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_hint" />

    <Spinner
        android:id="@+id/spinnerCashAccount"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_input_surface"
        android:backgroundTint="@null"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:popupBackground="@drawable/bg_spinner_popup"
        android:spinnerMode="dropdown" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="vertical">

        <Button
            android:id="@+id/btnCancelCashDialog"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:background="@drawable/bg_button_light"
            android:backgroundTint="@null"
            app:backgroundTint="@null"
            android:fontFamily="sans-serif-medium"
            android:text="@string/cancel"
            android:textAllCaps="false"
            android:textColor="@color/button_text_dark" />

        <Button
            android:id="@+id/btnDeleteCashDialog"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_button_light"
            android:backgroundTint="@null"
            app:backgroundTint="@null"
            android:fontFamily="sans-serif-medium"
            android:text="@string/delete_entry"
            android:textAllCaps="false"
            android:textColor="@color/amount_negative" />

        <Button
            android:id="@+id/btnSaveCashDialog"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_bottom_nav_item_selected"
            android:backgroundTint="@null"
            app:backgroundTint="@null"
            android:fontFamily="sans-serif-medium"
            android:text="@string/save_changes"
            android:textAllCaps="false"
            android:textColor="@color/text_primary" />
    </LinearLayout>
</LinearLayout>
