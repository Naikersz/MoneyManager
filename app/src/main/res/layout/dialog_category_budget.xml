<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_card_primary"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/tvCategoryBudgetTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/text_primary"
        android:textSize="20sp"
        android:textStyle="bold"
        tools:text="Budget: Groceries" />

    <TextView
        android:id="@+id/tvCategoryBudgetSpent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        tools:text="Spent in selected month: 120.00 EUR" />

    <EditText
        android:id="@+id/etCategoryBudgetAmount"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="14dp"
        android:background="@drawable/bg_input_surface"
        android:backgroundTint="@null"
        android:gravity="center_vertical"
        android:hint="@string/category_budget_hint"
        android:inputType="numberDecimal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_hint" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="vertical">

        <Button
            android:id="@+id/btnCancelCategoryBudgetDialog"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:background="@drawable/bg_button_light"
            android:backgroundTint="@null"
            app:backgroundTint="@null"
            android:fontFamily="sans-serif-medium"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:text="@string/cancel"
            android:textAllCaps="false"
            android:textColor="@color/button_text_dark" />

        <Button
            android:id="@+id/btnDeleteCategoryBudgetDialog"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_button_light"
            android:backgroundTint="@null"
            app:backgroundTint="@null"
            android:fontFamily="sans-serif-medium"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:text="@string/delete_budget"
            android:textAllCaps="false"
            android:textColor="@color/button_text_dark"
            android:visibility="gone" />

        <Button
            android:id="@+id/btnSaveCategoryBudgetDialog"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_button_dark"
            android:backgroundTint="@null"
            app:backgroundTint="@null"
            android:fontFamily="sans-serif-medium"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:text="@string/save_changes"
            android:textAllCaps="false"
            android:textColor="@color/button_text_light" />
    </LinearLayout>

</LinearLayout>
