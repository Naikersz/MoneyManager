<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_home_balance_card"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/tvCategoryDialogTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/add_category"
        android:textColor="@color/text_primary"
        android:textSize="20sp"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/etName"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="14dp"
        android:background="@drawable/bg_input_surface"
        android:backgroundTint="@null"
        android:gravity="center_vertical"
        android:hint="@string/category_name"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_hint" />

    <Button
        android:id="@+id/btnChoosePopularCategory"
        android:layout_width="match_parent"
        android:layout_height="46dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_button_light"
        android:backgroundTint="@null"
        app:backgroundTint="@null"
        android:fontFamily="sans-serif-medium"
        android:text="@string/choose_popular_category"
        android:textAllCaps="false"
        android:textColor="@color/button_text_dark" />

    <CheckBox
        android:id="@+id/cbFavoriteCategory"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginTop="8dp"
        android:buttonTint="@color/tab_badge"
        android:text="@string/category_favorite"
        android:textColor="@color/text_primary"
        android:textSize="14sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="vertical">

        <Button
            android:id="@+id/btnCancelCategoryDialog"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:background="@drawable/bg_button_light"
            android:backgroundTint="@null"
            app:backgroundTint="@null"
            android:fontFamily="sans-serif-medium"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:text="@string/cancel"
            android:textAllCaps="false"
            android:textColor="@color/button_text_dark" />

        <Button
            android:id="@+id/btnDeleteCategoryDialog"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_button_light"
            android:backgroundTint="@null"
            app:backgroundTint="@null"
            android:fontFamily="sans-serif-medium"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:text="@string/delete_entry"
            android:textAllCaps="false"
            android:textColor="@color/button_text_dark"
            android:visibility="gone" />

        <Button
            android:id="@+id/btnPrimaryCategoryDialog"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_button_dark"
            android:backgroundTint="@null"
            app:backgroundTint="@null"
            android:fontFamily="sans-serif-medium"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:text="@string/save_changes"
            android:textAllCaps="false"
            android:textColor="@color/button_text_light" />
    </LinearLayout>

</LinearLayout>
